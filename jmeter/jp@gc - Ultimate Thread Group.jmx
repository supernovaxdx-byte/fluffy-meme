        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import java.util.UUID
import java.util.Random

def rnd = new Random()

// UUID
vars.put(&quot;msg_id&quot;, UUID.randomUUID().toString())

// Пол
def isMale = rnd.nextBoolean()

def surname
def name
def patronymic

if (isMale) {
    surname = vars.get(&quot;male_surname&quot;)
    name = vars.get(&quot;male_name&quot;)
    patronymic = vars.get(&quot;male_patronymic&quot;)
} else {
    surname = vars.get(&quot;female_surname&quot;)
    name = vars.get(&quot;female_name&quot;)
    patronymic = vars.get(&quot;female_patronymic&quot;)
}

vars.put(&quot;full_name&quot;, &quot;${surname} ${name} ${patronymic}&quot;)

// Генерация ИНН ФЛ
int[] digits = new int[12]

for (int i = 0; i &lt; 10; i++) {
    digits[i] = rnd.nextInt(10)
}

def checksum = { nums, coeffs -&gt;
    int sum = 0
    for (int i = 0; i &lt; coeffs.size(); i++) {
        sum += nums[i] * coeffs[i]
    }
    return (sum % 11) % 10
}

digits[10] = checksum(
        digits,
        [7,2,4,10,3,5,9,4,6,8]
)

digits[11] = checksum(
        digits,
        [3,7,2,4,10,3,5,9,4,6,8]
)

vars.put(&quot;inn&quot;, digits.join(&quot;&quot;))</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
